];

// --- Fetch from DB or fallback to mock ---
let profile: Profile | null = mockProfile;
let projects: Project[] = mockProjects;
let certifications: Certification[] = mockCerts;
let skills: Skill[] = mockSkills;

try {
  const { query } = await import('../lib/db');
  const [dbProfile, dbProjects, dbCerts, dbSkills] = await Promise.all([
    query<Profile>('SELECT * FROM profile LIMIT 1'),
    query<Project>('SELECT * FROM projects ORDER BY featured DESC, created_at DESC'),
    query<Certification>('SELECT * FROM certifications ORDER BY issue_date DESC'),
    query<Skill>('SELECT * FROM skills ORDER BY category, level DESC'),
  ]);
  if (dbProfile.length > 0) profile = dbProfile[0];
  if (dbProjects.length > 0) projects = dbProjects;
  if (dbCerts.length > 0) certifications = dbCerts;
  if (dbSkills.length > 0) skills = dbSkills;
} catch {
  // DB not available — using mock data
}

const skillsByCategory: SkillsByCategory = skills.reduce((acc, skill) => {
  if (!acc[skill.category]) acc[skill.category] = [];
  acc[skill.category].push(skill);
  return acc;
}, {} as SkillsByCategory);
---

<BaseLayout title={`${profile?.name ?? 'Portafolio'} | Full Stack Developer`}>
  <Hero profile={profile} />
  <About profile={profile} projectCount={projects.length} certCount={certifications.length} />
  <Skills skillsByCategory={skillsByCategory} />
  <ProjectsGrid client:load projects={projects} />
  <Certifications certifications={certifications} />
  <ContactForm client:load email={profile?.email} location={profile?.location} availability={profile?.availability} />
</BaseLayout>
