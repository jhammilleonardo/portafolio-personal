---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ProjectsGrid } from '../components/sections/ProjectsGrid';
import type { Project } from '../types';

let projects: Project[] = [];

try {
  const { query } = await import('../lib/db');
  projects = await query<Project>('SELECT * FROM projects ORDER BY featured DESC, created_at DESC');
} catch {
  // fallback vacío
}
---

<BaseLayout title="Proyectos | Portafolio" description="Todos mis proyectos de desarrollo web y software.">
  <div class="pt-20">
    <ProjectsGrid client:load projects={projects} />
  </div>
</BaseLayout>
